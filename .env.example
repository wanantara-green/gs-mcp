# ──────────────────────────────────────────────────────────
# GeoServer Stack — Environment Configuration (TEMPLATE)
# ──────────────────────────────────────────────────────────
# Copy ke .env di root repo lalu isi nilai sesuai environment Anda:
#
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
#
# .env sudah di-.gitignore — JANGAN commit. File ini (.env.example) yang
# di-track sebagai dokumentasi env yang dipakai docker-compose.yaml.

# ── GeoServer Admin ──────────────────────────────────────
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver

# ── PostGIS ──────────────────────────────────────────────
POSTGIS_DB=geoserver
POSTGIS_USER=geoserver
POSTGIS_PASS=geoserver

# ── GeoServer MCP ────────────────────────────────────────
# URL GeoServer (tanpa slash di akhir).
# Internal (dalam Docker network): http://geoserver:8080/geoserver
# Eksternal (dari browser host)  : http://localhost:9597/geoserver
GEOSERVER_URL=http://geoserver:8080/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=${GEOSERVER_ADMIN_PASSWORD}

# Nama workspace di GeoServer (dipakai geoserver-init & gs-ai-bridge).
GEOSERVER_WORKSPACE=zonasiluwu

# ── GS AI Bridge ─────────────────────────────────────────
# WAJIB diisi kalau Anda menjalankan service gs-ai-bridge (endpoint /ask).
# Tanpa key, container tetap up tapi setiap /ask gagal autentikasi ke
# DeepSeek dan compose mengeluarkan warning "variable not set".
# Kalau cuma butuh peta WFS (tanpa LLM), boleh skip service-nya:
#   docker compose up -d postgis geoserver postgis-seed geoserver-init geoserver-mcp
DEEPSEEK_API_KEY=

DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
GEOSERVER_MCP_SSE_URL=http://geoserver-mcp:8000/sse

# Origin yang boleh memanggil POST /ask dari browser. Boleh banyak,
# pisahkan koma. Untuk dev lokal mis. http://localhost:5500,http://127.0.0.1:5500
ALLOWED_ORIGIN=https://training-02.wanantara.org

# ── Seed (opsional) ──────────────────────────────────────
# Set ke 1 untuk memaksa re-import semua GeoJSON walau tabel sudah ada.
# Default 0 (idempoten — skip tabel yang sudah berisi baris).
SEED_FORCE=0
