# ──────────────────────────────────────────────────────────
# GeoServer Stack — Environment Configuration
# ──────────────────────────────────────────────────────────
# Dibaca otomatis oleh docker compose.

# ── GeoServer Admin ──────────────────────────────────────
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver

# ── PostGIS ──────────────────────────────────────────────
POSTGIS_DB=geoserver
POSTGIS_USER=geoserver
POSTGIS_PASS=geoserver

# ── GeoServer MCP ────────────────────────────────────────
# URL lengkap server GeoServer (tanpa slash di akhir)
# Internal (dalam Docker network): http://geoserver:8080/geoserver
# Eksternal (dari browser)      : http://localhost:9597/geoserver
GEOSERVER_URL=http://geoserver:8080/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=${GEOSERVER_ADMIN_PASSWORD}

# Nama Workspace di GeoServer
GEOSERVER_WORKSPACE=zonasiluwu
